#include<stdio.h>
#define size 10

void sort(int p[],int at[], int bt[],int n)
{
    int temp=0;
    for (int i=0;i<n;i++)
    {
        for (int j=0;j<(n-i);j++)
        {
	      if (at[j]>at[j+1])
	      {
	          temp=at[j];
	          at[j]=at[j+1];
	          at[j+1]=temp;
	
	          temp=bt[j+1];
	          bt[j+1]=bt[j];
	          bt[j]=temp;
	          
	          temp=p[j];
	          p[j]=p[j+1];
	          p[j+1]=temp;
	      }
	  }
    }
}

int main()
{
    int p[size], at[size], bt[size], ct[size], tat[size], wt[size], rt[size],i, j, temp=0, n;
    float awt=0, atat=0;
    printf("Enter no. of process: ");
    scanf("%d",&n);
    for(i=0; i<n; i++)
    {
        printf("Enter Process %d Id: ", i+1);
        scanf("%d",&p[i]);
        printf("Enter Process %d Arrival Time: ", i+1);
        scanf("%d",&at[i]);
        printf("Enter Process %d Burst Time: ", i+1);
        scanf("%d",&bt[i]);
    }
    sort(p,at,bt,n);
    ct[0]=at[0]+bt[0];
    for(i=1;i<n;i++)
    {
        temp=0;
        if(ct[i-1]<at[i])
        {
            temp=at[i]-ct[i-1];
        }
        ct[i]=ct[i-1]+bt[i]+temp;
    }
    printf("P\tAT\tBT\tCT\tTAT\tWT\tRT\n");
    for(i=0;i<n;i++)
    {
        tat[i]=ct[i]-at[i];
        wt[i]=tat[i]-bt[i];
        rt[i]=ct[i]-bt[i]-at[i];
        atat += tat[i];
        awt += wt[i];
    }
    atat=atat/n;
    awt=awt/n;
    for(i=0;i<n;i++)
    {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",p[i],at[i],bt[i],ct[i],tat[i],wt[i],rt[i]);
    }
    printf("Avg. TAT = %.2f\n",atat);
    printf("Avg. WT = %.2f\n",awt);
    return 0;
}
